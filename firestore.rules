rules_version = '2';

// ============================================================================
// REGLAS DE SEGURIDAD DE FIRESTORE — Libre Pedal
// Lectura pública (la comunidad se ve siempre). Escritura SOLO autenticada, con
// límites de tamaño para evitar abuso y "bombas" de datos, y verificación de
// dueño real donde corresponde (ver isOwnerOrLegacy / isAdmin más abajo).
//
// AUTH (actualizado 2026-07-12): la app arranca con Auth ANÓNIMA (uid aleatorio,
// para no bloquear a nadie apenas abre la app), pero apenas se conoce tu `cu`
// (login o registro) la sube a un token personalizado de Firebase — emitido por
// el Worker `librepedal-auth` — que fija tu uid de Firebase Auth a tu `cu` real,
// ESTABLE en cualquier dispositivo. Con eso, `request.auth.uid` puede compararse
// directo contra el campo `user` que YA se guarda en cada documento desde
// siempre — protege también los documentos viejos, sin tener que re-escribir
// nada. Si el Worker de tokens no responde (sin señal, caído), la app sigue con
// la sesión anónima de siempre — no se rompe el login, solo queda con protección
// parcial hasta que pueda re-intentar. Detalle completo en
// COORDINACION-IA/BITACORA.md, entrada 2026-07-12.
//
// CÓMO PUBLICAR CAMBIOS A ESTE ARCHIVO (en orden, importante):
//   1) Firebase Console -> Firestore Database -> pestaña Reglas -> pega esto -> Publicar.
//   2) Si tocaste algo admin-only (novedades/retos/frasesComunidad), recarga la
//      app UNA vez antes de usar el panel de admin — así tu sesión sube al
//      token personalizado y `isAdmin()` te reconoce.
//   Si algo se rompe, vuelve a las reglas abiertas temporalmente.
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    // true si el campo no viene, o si es string y no supera n caracteres
    function strOk(f, n) {
      return !(f in request.resource.data)
        || (request.resource.data[f] is string && request.resource.data[f].size() <= n);
    }
    // Dueño real. Dos vías, la primera es la buena y cubre TODO (documentos
    // viejos y nuevos) para quien ya se autenticó con el token personalizado:
    //  1) isOwnerByCu(): el campo `user` del documento (tu `cu`, se guarda desde
    //     siempre) coincide con tu uid de Firebase Auth de hoy.
    //  2) authUid == uid, con grandfather si el campo ni existe: respaldo para
    //     mientras el usuario sigue en la sesión anónima vieja (no se rompe nada
    //     hasta que recargue y su auth suba sola al token personalizado).
    function isOwnerByCu() {
      return 'user' in resource.data && resource.data.user == request.auth.uid;
    }
    function isOwnerOrLegacy() {
      return isOwnerByCu()
        || !('authUid' in resource.data) || resource.data.authUid == request.auth.uid;
    }
    // Admin real: tu `cu` (correo transformado) es literalmente el uid de Firebase
    // Auth una vez que tu sesión subió al token personalizado — antes de eso
    // (sesión anónima vieja, sin recargar) esto da false, ver nota de arriba.
    function isAdmin() {
      return request.auth.uid == 'intyrivera_a_gmail_com';
    }

    // Perfiles de ciclistas. update restringido al dueño real: antes cualquier
    // usuario autenticado podía sobrescribir el perfil de OTRO (nombre, casco,
    // skin) con solo saber su `cu`.
    match /users/{id} {
      allow read: if true;
      allow create: if signedIn() && strOk('nombre', 60) && strOk('email', 120) && strOk('helmet', 40) && strOk('skin', 30);
      allow update: if signedIn() && strOk('nombre', 60) && strOk('email', 120) && strOk('helmet', 40) && strOk('skin', 30) && isOwnerOrLegacy();
      allow delete: if false;
    }

    // Chat global de la comunidad
    match /chat/{id} {
      allow read: if true;
      allow create: if signedIn() && strOk('t', 500) && strOk('nombre', 60);
      allow update, delete: if signedIn();
    }

    // Mapa comunitario "Reportar en Ruta". Nadie lo edita/borra salvo quien lo creó
    // (o cualquiera, en documentos de antes de este cambio — ver isOwnerOrLegacy).
    match /reportes/{id} {
      allow read: if true;
      allow create: if signedIn() && strOk('text', 600) && strOk('comuna', 80) && strOk('cat', 30);
      allow update, delete: if signedIn() && isOwnerOrLegacy();
    }

    // Alertas de ruta
    match /routeAlerts/{id} {
      allow read: if true;
      allow create: if signedIn() && strOk('desc', 500) && strOk('type', 60);
      allow update, delete: if signedIn();
    }

    // Comentarios de la CicloGuía
    match /guiComments/{id} {
      allow read: if true;
      allow create: if signedIn() && strOk('text', 500);
      allow update, delete: if signedIn() && isOwnerOrLegacy();
    }

    // Recomendaciones. update queda abierto a signedIn(): "me gusta" (likes/likedBy)
    // lo actualiza CUALQUIER usuario, no solo el dueño — es el comportamiento real
    // de la función. delete sí se restringe: nadie borra la recomendación de otro.
    match /recommendations/{id} {
      allow read: if true;
      allow create, update: if signedIn() && strOk('title', 120) && strOk('desc', 800);
      allow delete: if signedIn() && isOwnerOrLegacy();
    }

    // Hospedajes / campings. update queda abierto: las calificaciones (estrellas)
    // las pone cualquier usuario, no solo el dueño. delete sí se restringe.
    match /hostels/{id} {
      allow read: if true;
      allow create: if signedIn() && strOk('name', 120) && strOk('location', 200) && strOk('desc', 800);
      allow update: if signedIn();
      allow delete: if signedIn() && isOwnerOrLegacy();
    }

    // Tips de taller (MacGyver)
    match /repairTips/{id} {
      allow read: if true;
      allow create: if signedIn() && strOk('title', 120) && strOk('desc', 1000);
      allow update, delete: if signedIn() && isOwnerOrLegacy();
    }

    // Rutas grabadas (públicas). update/delete permitidos: la app actualiza la
    // misma ruta mientras la vas grabando (checkpoints) y el usuario puede borrar
    // las suyas desde "Mis Rutas" — con "if false" ninguna de las dos cosas
    // funcionaba de verdad (la app lo ocultaba con un catch silencioso). Restringido
    // al dueño real: nadie más tiene por qué tocar tu ruta grabada.
    match /routes/{id} {
      allow read: if true;
      allow create: if signedIn() && strOk('hospedaje', 200) && strOk('notasDelDia', 3000);
      allow update, delete: if signedIn() && isOwnerOrLegacy() && strOk('hospedaje', 200) && strOk('notasDelDia', 3000);
    }

    // Viajes planificados (el usuario gestiona los suyos desde la app)
    match /trips/{id} {
      allow read: if true;
      allow create: if signedIn();
      allow update, delete: if signedIn() && isOwnerOrLegacy();
    }

    // Solicitudes de amistad. update queda abierto: quien las ACEPTA/RECHAZA es el
    // destinatario, no quien las creó — restringirlo a isOwnerOrLegacy rompería esa
    // función. delete sí se restringe al que la envió (hoy la app no borra
    // solicitudes, pero si algo llega a hacerlo, que sea solo el propio remitente).
    match /friendRequests/{id} {
      allow read: if true;
      allow create: if signedIn();
      allow update: if signedIn();
      allow delete: if signedIn() && isOwnerOrLegacy();
    }

    // Diario personal (respaldo en la nube). Privacidad real: la migración a
    // auth.uid (v6.12) ya está lista para esto, pero nadie la había aplicado acá
    // — CUALQUIER usuario logueado podía leer, sobrescribir o borrar el diario de
    // OTRO usuario (reflexiones privadas), con el ID de documento predecible
    // (`{cu}_{fecha}`). OJO: isOwnerOrLegacy() NO sirve para esta colección — su
    // "grandfather" da por dueño a cualquiera cuando el documento no tiene el campo
    // `authUid`, y los diarios NUNCA lo tienen (usan `user`), así que habría quedado
    // siempre abierto. Se usa isOwnerByCu() solo, y en `create` se exige además que
    // el campo `user` sea tu propio uid (si no, alguien podría "adelantarse" y crear
    // el documento de otro usuario con contenido propio antes de que ese usuario
    // escriba el suyo).
    match /diarios/{id} {
      allow read: if signedIn() && isOwnerByCu();
      allow create: if signedIn() && request.resource.data.user == request.auth.uid && strOk('reflexion', 2000) && strOk('complejo', 2000) && strOk('meta', 300);
      allow update: if signedIn() && isOwnerByCu() && strOk('reflexion', 2000) && strOk('complejo', 2000) && strOk('meta', 300);
      allow delete: if signedIn() && isOwnerByCu();
    }

    // Mensajes privados entre amigos. Solo quien lo escribió puede editarlo/borrarlo.
    match /dm/{conversationId}/messages/{msgId} {
      allow read: if signedIn();
      allow create: if signedIn() && strOk('text', 1000);
      allow update, delete: if signedIn() && isOwnerOrLegacy();
    }

    // Te doy alojo (solo usuarios con 6+ meses, verificado en la app)
    match /alojo/{id} {
      allow read: if signedIn();
      allow create: if signedIn() && strOk('desc', 600) && strOk('zona', 100);
      allow update, delete: if signedIn() && isOwnerOrLegacy();
    }

    // Votación de comunidad (un voto por usuario, id del doc = su propio usuario)
    match /votacionComunidad/{id} {
      allow read: if true;
      allow create, update: if signedIn() && strOk('opcion', 40);
      allow delete: if signedIn();
    }

    // Sorteo de comunidad (una participación por usuario; lista pública para transparencia)
    match /sorteoComunidad/{id} {
      allow read: if true;
      allow create: if signedIn() && strOk('nombre', 60);
      allow update, delete: if signedIn();
    }

    // Frases que aporta la comunidad para que Pistero las diga en la app. Quedan en
    // revisión (aprobada:false) hasta que el ADMIN (de verdad, ver isAdmin) las
    // aprueba/rechaza — antes cualquier signedIn() podía auto-aprobarse o borrar
    // frases ajenas llamando la API directo, aunque la UI lo ocultara.
    match /frasesComunidad/{id} {
      allow read: if true;
      allow create: if signedIn() && strOk('texto', 140) && strOk('nombre', 60);
      allow update, delete: if isAdmin();
    }

    // Novedades del mundo del ciclismo en Chile (competencias, rodadas, cicloturismo).
    // Las publica el ADMIN (de verdad, ver isAdmin) desde el panel de Perfil; antes
    // cualquier signedIn() podía publicar "Novedades" falsas llamando la API directo.
    match /novedades/{id} {
      allow read: if true;
      allow create, update: if isAdmin() && strOk('titulo', 120) && strOk('desc', 800) && strOk('categoria', 30) && strOk('link', 300) && strOk('fecha', 60);
      allow delete: if isAdmin();
    }

    // Seguimiento en vivo: comparte tu ubicación con un link (quien lo abre no
    // necesita cuenta ni la app instalada). Lectura pública a propósito.
    match /liveTracking/{id} {
      allow read: if true;
      allow create, update: if signedIn() && strOk('nombre', 60);
      allow delete: if signedIn();
    }

    // Segmentos (tramos para competir por mejor tiempo, estilo Strava) y sus marcas.
    match /segmentos/{id} {
      allow read: if true;
      allow create: if signedIn() && strOk('nombre', 80) && strOk('desc', 300);
      allow update, delete: if signedIn();
    }
    match /segmentoTiempos/{id} {
      allow read: if true;
      allow create: if signedIn() && strOk('nombre', 60) && strOk('segmentoId', 100);
      allow update, delete: if signedIn() && isOwnerOrLegacy();
    }

    // Retos y temporadas (desafíos con fecha límite sobre el Darma existente).
    // Los publica el ADMIN (de verdad, ver isAdmin) desde Ajustes; antes cualquier
    // signedIn() podía crear/editar retos falsos llamando la API directo.
    match /retos/{id} {
      allow read: if true;
      allow create: if isAdmin() && strOk('titulo', 100) && strOk('desc', 400);
      allow update, delete: if isAdmin();
    }

    // Rodadas grupales (salidas con fecha/hora/punto de encuentro). update queda
    // abierto a signedIn(): es como CUALQUIER asistente marca "voy"/"no voy" (lista
    // de asistentes), no solo quien la creó. delete sí se restringe al creador.
    match /rodadas/{id} {
      allow read: if true;
      allow create, update: if signedIn() && strOk('titulo', 100) && strOk('puntoEncuentro', 150) && strOk('desc', 400);
      allow delete: if signedIn() && isOwnerOrLegacy();
    }

    // Todo lo demás: denegado por defecto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
