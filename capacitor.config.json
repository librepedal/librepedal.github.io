{
  "appId": "cl.librepedal.app",
  "appName": "Libre Pedal",
  "webDir": "www",
  "server": {
    "url": "https://librepedal.github.io",
    "androidScheme": "https",
    "allowNavigation": [
      "librepedal.github.io",
      "*.openstreetmap.org",
      "*.tile.openstreetmap.org",
      "*.tile.opentopomap.org",
      "router.project-osrm.org",
      "nominatim.openstreetmap.org",
      "tiles.openfreemap.org",
      "tiles.mapterhorn.com",
      "unpkg.com",
      "*.gstatic.com",
      "*.googleapis.com",
      "*.firebaseio.com",
      "firestore.googleapis.com"
    ]
  },
  "plugins": {
    "BackgroundGeolocation": {}
  }
}
